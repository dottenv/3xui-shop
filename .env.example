# ============================================
# CWIM - VPN Subscription Shop
# ============================================
# Скопируйте этот файл в .env и заполните значения

# === Домены ===
SITE_DOMAIN=cwim.ru
APP_DOMAIN=app.cwim.ru
CRM_DOMAIN=crm.cwim.ru

# === SSL (Let's Encrypt) ===
# ⚠️  Перед запуском: DNS A-записи для всех доменов должны указывать на IP сервера
#     Иначе Let's Encrypt не сможет выпустить сертификаты!
# Для тестирования без rate limit: раскомментируй caserver в docker-compose.yml
LETSENCRYPT_EMAIL=admin@cwim.ru

# === База данных ===
DATABASE_URL=sqlite:///app/data/database.db

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === API Security ===
API_SECRET_KEY=super-secret-random-string-change-me

# ============================================
# Payment Gateways (включайте по необходимости)
# ============================================

# --- Cryptomus (криптовалюта) ---
CRYPTOMUS_ENABLED=false
CRYPTOMUS_API_KEY=your-cryptomus-api-key
CRYPTOMUS_MERCHANT_UUID=your-cryptomus-merchant-uuid
CRYPTOMUS_WEBHOOK_SECRET=your-cryptomus-webhook-secret

# --- Heleket (криптовалюта) ---
HELEKET_ENABLED=false
HELEKET_API_KEY=your-heleket-api-key
HELEKET_MERCHANT_UUID=your-heleket-merchant-uuid
HELEKET_WEBHOOK_SECRET=your-heleket-webhook-secret

# --- YooKassa (банковские карты) ---
YOOKASSA_ENABLED=false
YOOKASSA_SHOP_ID=your-yookassa-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret-key

# --- YooMoney (электронный кошелёк) ---
YOOMONEY_ENABLED=false
YOOMONEY_SHOP_ID=your-yoomoney-shop-id
YOOMONEY_SECRET_KEY=your-yoomoney-secret-key
